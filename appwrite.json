    "buckets": [
        {
            "$id": "media",
            "$permissions": [
                "create(\"users\")"
            ],
            "fileSecurity": true,
            "name": "media",
            "enabled": true,
            "maximumFileSize": 10485760,
            "allowedFileExtensions": [
                "jpg",
                "jpeg",
                "png",
                "webp"
            ],
            "compression": "none",
            "encryption": true,
            "antivirus": true
        }
