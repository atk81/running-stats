{
    "projectId": "69f5e1d0002c4fd86283",
    "projectName": "runStats",
    "endpoint": "https://cloud.appwrite.io/v1",
    "databases": [
        {
            "$id": "runstats_db",
            "name": "runstats",
            "enabled": true
        }
    ],
    "collections": [
        {
            "$id": "users",
            "$permissions": [
                "create(\"users\")"
            ],
            "databaseId": "runstats_db",
            "name": "users",
            "enabled": true,
            "documentSecurity": true,
            "attributes": [
                {
                    "key": "userId",
                    "type": "string",
                    "size": 36,
                    "required": true,
                    "array": false
                },
                {
                    "key": "name",
                    "type": "string",
                    "size": 128,
                    "required": true,
                    "array": false
                },
                {
                    "key": "handle",
                    "type": "string",
                    "size": 64,
                    "required": true,
                    "array": false
                },
                {
                    "key": "city",
                    "type": "string",
                    "size": 128,
                    "required": false,
                    "array": false
                },
                {
                    "key": "avatarFileId",
                    "type": "string",
                    "size": 36,
                    "required": false,
                    "array": false
                },
                {
                    "key": "accentColor",
                    "type": "string",
                    "size": 7,
                    "required": false,
                    "array": false,
                    "default": "#FF6800"
                },
                {
                    "key": "stravaAthleteId",
                    "type": "string",
                    "size": 20,
                    "required": true,
                    "array": false
                },
                {
                    "key": "stravaAccessToken",
                    "type": "string",
                    "size": 256,
                    "required": false,
                    "array": false
                },
                {
                    "key": "stravaRefreshToken",
                    "type": "string",
                    "size": 256,
                    "required": false,
                    "array": false
                },
                {
                    "key": "stravaTokenExpiresAt",
                    "type": "integer",
                    "required": false,
                    "array": false
                },
                {
                    "key": "autoSharePR",
                    "type": "boolean",
                    "required": false,
                    "array": false,
                    "default": true
                },
                {
                    "key": "autoShareVolume",
                    "type": "boolean",
                    "required": false,
                    "array": false,
                    "default": true
                },
                {
                    "key": "autoShareWeeklyRecap",
                    "type": "boolean",
                    "required": false,
                    "array": false,
                    "default": true
                },
                {
                    "key": "onboardingComplete",
                    "type": "boolean",
                    "required": false,
                    "array": false,
                    "default": false
                },
                {
                    "key": "lastSyncAt",
                    "type": "datetime",
                    "required": false,
                    "array": false
                }
            ],
            "indexes": [
                {
                    "key": "idx_user_id",
                    "type": "key",
                    "attributes": [
                        "userId"
                    ],
                    "orders": [
                        "ASC"
                    ]
                },
                {
                    "key": "idx_strava_athlete_id",
                    "type": "unique",
                    "attributes": [
                        "stravaAthleteId"
                    ],
                    "orders": [
                        "ASC"
                    ]
                },
                {
                    "key": "idx_handle",
                    "type": "unique",
                    "attributes": [
                        "handle"
                    ],
                    "orders": [
                        "ASC"
                    ]
                }
            ]
        },
        {
            "$id": "goals",
            "$permissions": [
                "create(\"users\")"
            ],
            "databaseId": "runstats_db",
            "name": "goals",
            "enabled": true,
            "documentSecurity": true,
            "attributes": [
                {
                    "key": "userId",
                    "type": "string",
                    "size": 36,
                    "required": true,
                    "array": false
                },
                {
                    "key": "goalKey",
                    "type": "string",
                    "size": 32,
                    "required": true,
                    "array": false
                },
                {
                    "key": "name",
                    "type": "string",
                    "size": 128,
                    "required": true,
                    "array": false
                },
                {
                    "key": "type",
                    "type": "string",
                    "size": 16,
                    "required": true,
                    "array": false
                },
                {
                    "key": "distanceLabel",
                    "type": "string",
                    "size": 64,
                    "required": false,
                    "array": false
                },
                {
                    "key": "targetValue",
                    "type": "string",
                    "size": 32,
                    "required": true,
                    "array": false
                },
                {
                    "key": "targetSeconds",
                    "type": "integer",
                    "required": false,
                    "array": false
                },
                {
                    "key": "currentValue",
                    "type": "string",
                    "size": 32,
                    "required": false,
                    "array": false
                },
                {
                    "key": "currentSeconds",
                    "type": "integer",
                    "required": false,
                    "array": false
                },
                {
                    "key": "percentage",
                    "type": "integer",
                    "required": false,
                    "array": false,
                    "min": 0,
                    "max": 100,
                    "default": 0
                },
                {
                    "key": "done",
                    "type": "boolean",
                    "required": false,
                    "array": false,
                    "default": false
                },
                {
                    "key": "doneAt",
                    "type": "datetime",
                    "required": false,
                    "array": false
                },
                {
                    "key": "year",
                    "type": "integer",
                    "required": true,
                    "array": false,
                    "min": 2000,
                    "max": 2100
                },
                {
                    "key": "isBuiltin",
                    "type": "boolean",
                    "required": false,
                    "array": false,
                    "default": false
                }
            ],
            "indexes": [
                {
                    "key": "idx_user_year",
                    "type": "key",
                    "attributes": [
                        "userId",
                        "year"
                    ],
                    "orders": [
                        "ASC",
                        "DESC"
                    ]
                },
                {
                    "key": "idx_user_goal_key",
                    "type": "unique",
                    "attributes": [
                        "userId",
                        "goalKey",
                        "year"
                    ],
                    "orders": [
                        "ASC",
                        "ASC",
                        "ASC"
                    ]
                }
            ]
        },
