                    ]
                },
                {
                    "key": "idx_user_processed",
                    "type": "key",
                    "attributes": [
                        "userId",
                        "processed"
                    ],
                    "orders": [
                        "ASC",
                        "ASC"
                    ]
                }
            ]
        },
